# 환경변수 설정 (키 없어도 mock 데이터로 동작)
# 아래 값을 실제 키로 교체하세요

# 한국관광공사 TourAPI (https://www.data.go.kr)
TOUR_API_KEY=YOUR_TOUR_API_KEY_HERE

# 카카오맵 JavaScript 앱 키 (https://developers.kakao.com)
KAKAO_MAP_KEY=YOUR_KAKAO_MAP_KEY_HERE

# Google Gemini API (https://aistudio.google.com) — 없으면 AI 설명 생략
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# 기상청 단기예보 API (https://www.data.go.kr) — 없으면 날씨 연동 생략
WEATHER_KEY=YOUR_WEATHER_KEY_HERE

# 배포 URL로 변경 (Railway 배포 후 발급된 URL 입력)
ALLOWED_ORIGINS=https://your-app.up.railway.app
